# Copy to /etc/cronova/cronova.env and chmod 600 (root-only).
# systemd loads this via EnvironmentFile= in cronova.service.
# These CRONOVA_* vars override cronova.yaml (flags still win over env).

# Create or rotate the admin with `cronova init`; credentials are hashed directly
# into SQLite and should not be kept in this long-lived service environment.

# Mark the session cookie Secure when serving behind HTTPS.
# CRONOVA_SECURE_COOKIE=true

# Example non-secret overrides:
# CRONOVA_AUDIT_RETENTION=8760h
# CRONOVA_TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
