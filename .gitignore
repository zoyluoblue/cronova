.DS_Store
# local secrets / env files (never commit)
.env
*.db
*.db-wal
*.db-shm
*.db-journal
# built binaries at repo root (anchored so they don't match cmd/cronova* source dirs)
/cronova
/cronova-executor
# release artifacts (make release)
/dist/
/data/
/logs/
# scratch screenshots / working artifacts (never commit)
/tmp/
node_modules/
# mkdocs build output + docs venv
/site/
/.venv-docs/
