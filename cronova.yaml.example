# cronova configuration — copy to cronova.yaml (every key is optional).
# `cronova init` writes this file for you; edit by hand for advanced tweaks.
# Precedence, highest first:  flag  >  CRONOVA_* env  >  this file  >  built-in default.

# ── HTTP console + API ──────────────────────────────────────────────────────
# ":8090"          all interfaces (reachable by the server's IP)
# "127.0.0.1:8090" this machine only (put a reverse proxy in front for remote use)
# ""               disables the console/API entirely (scheduler still runs)
http: ":8090"

# ── Scheduler ───────────────────────────────────────────────────────────────
tick: 2s                    # how often the loop wakes to schedule/poll work

# Task executor. Empty = in-process (tasks die on a scheduler restart).
# A gRPC target keeps tasks alive across restarts (crash recovery), e.g.:
#   executor: "unix:///run/cronova/executor.sock"
executor: ""

# ── Authentication ──────────────────────────────────────────────────────────
auth:
  enabled: true             # require login for the console + API (recommended)
  session_ttl: 24h          # how long a login session stays valid
  secure_cookie: false      # set true when served over HTTPS (marks the cookie Secure)
  # Seed admin credentials: prefer the CRONOVA_ADMIN_USER / CRONOVA_ADMIN_PASSWORD
  # env vars (see cronova.env) over storing a password in this world-readable file.
  # admin_user: ""
  # admin_password: ""

# ── Storage paths ───────────────────────────────────────────────────────────
# Under systemd these are set by the service unit's flags (which win over this
# file); uncomment only for a manual, non-systemd run.
# db:   data/cronova.db     # SQLite metadata database
# dags: dags                # directory of DAG YAML definitions
# logs: logs                # directory for per-task log files

# Uploaded project files (console: task editor → 工程/Project). Each project is
# a directory here; a shell task with `project: <name>` runs its command inside
# a fresh temp copy of it. Default: ~/.cronova/projects (of the service user).
# Requires the scheduler and executor to share a filesystem (same host).
# projects: ~/.cronova/projects
